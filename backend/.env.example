# ================================================
# Auto Payment Gateway — Environment Variables
# Copy this to .env and fill in real values
# ================================================

# --- Database ---
# Development: SQLite
DATABASE_URL=sqlite:///./payment_system.db
# Production: uncomment and use PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/autopayment

# --- Telegram Worker ---
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Get this from @BotFather — used by merchants and admins
MANAGEMENT_BOT_TOKEN=123456789:AABBccDDeeFF_your_bot_token_here

# Comma-separated list of Telegram User IDs for admins
ADMIN_TELEGRAM_IDS=11111111,22222222

# --- Security ---
# Generate a Fernet key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# SENTRY (For Error Tracking)
# SENTRY_DSN=your_sentry_dsn_here

# CLOUDFLARE TUNNEL (For Public Domain Access)
# CLOUDFLARE_TUNNEL_TOKEN=your_token_here
